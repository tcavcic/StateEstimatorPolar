r_{ij_{Q}}(v,\varphi)=-v^{2}_{i}y^{(i\text{-}j)}_{ii}\sin(\theta^{(i\text{-}j)}_{ii})+v_{i}y^{(i\text{-}j)}_{ij}v_{j}\sin(\varphi_{i}-\theta^{(i\text{-}j)}_{ij}-\varphi_{j})-\hat{q}_{ij}
\]

