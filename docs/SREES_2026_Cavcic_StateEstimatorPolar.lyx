\begin_layout Section
\noindent
Algoritam estimacije stanja 
\end_layout

\begin_layout Standard
Estimacija stanja implementirana je u klasi 
\family typewriter
StateEstimator
\family default
 kao 
\series bold
nelinearni WLS
\series default
 (
\emph on
Weighted Least Squares
\emph default
) 
\series bold
estimator
\series default
 zasnovan na 
\series bold
Gauss-Newton metodi
\series default
,
 u 
\series bold
polarnim koordinatama
\series default
.
 Algoritam je potpuno odvojen od korisničkog interfejsa i komunicira s ostatkom aplikacije isključivo preko baze podataka (ulaz:
 topologija i mjerenja) i javnih struktura rezultata (izlaz).
\end_layout

\begin_layout Standard
\begin_inset VSpace defskip
\end_inset


\end_layout

\begin_layout Standard
\noindent

\emph on
Napomena:
 
\emph default
Jacobian 
\begin_inset Formula $H$
\end_inset

 se nikad ne formira eksplicitno,
 već za svako mjerenje se računa samo lista nenultih parova 
\begin_inset Formula $(kolona,vrijednost)$
\end_inset

 tog reda,
 koja se odmah kumulativno dodaje u gain-matricu i RHS vektor,
 
\begin_inset Formula $G\mathrel{+}=H^{\top}_{m,\cdot}w_{m}H_{m,\cdot}$
\end_inset

,
 
\begin_inset Formula $g\mathrel{+}=H^{\top}_{m,\cdot}w_{m}r_{m}$
\end_inset

,
 čime se izbjegava alokacija pune 
\begin_inset Formula $M\times n$
\end_inset

 matrice.
 Matrica 
\begin_inset Formula $Y_{bus}$
\end_inset

 implementirana je kao gusta (
\emph on
dense
\emph default
) matrica,
 jer joj se pristupa punim redovima pri računanju injektiranih snaga.
 Gain-matrica 
\begin_inset Formula $G=H^{\top}WH$
\end_inset

 implementirana je kao rijetka (
\emph on
sparse
\emph default
) matrica,
 budući da je njena rijetkost direktna posljedica rijetkosti 
\begin_inset Formula $H$
\end_inset

.
 Pošto je 
\begin_inset Formula $G$
\end_inset

 po konstrukciji simetrična i pozitivno (semi)definitna,
 za njeno rješavanje korištena je 
\begin_inset Formula $LDL^{\top}$
\end_inset

 faktorizacija (
\family typewriter
sparse::SolverType::LDLT,
 Symmetry::SymmetricPosDef
\family default
).
\end_layout

\begin_layout Subsection
Vektor stanja
\end_layout

\begin_layout Standard
Za mrežu sa 
\begin_inset Formula $N$
\end_inset

 čvorova,
 vektor stanja 
\begin_inset Formula $x$
\end_inset

 je definisan kao:
\begin_inset Formula 
\begin{equation}
x=\big[\varphi_{1},\varphi_{2},\ldots,\varphi_{N-1},V_{0},V_{1},\ldots,V_{N-1}\big]^{T}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\noindent
odnosno sadrži 
\begin_inset Formula $N-1$
\end_inset

 faznih uglova i 
\begin_inset Formula $N$
\end_inset

 napona,
 pa je ukupan broj nepoznatihn_
\begin_inset Formula $x=(N-1)+N=2N-1$
\end_inset

.
 Fazni ugao referentnog (
\begin_inset Formula $slack$
\end_inset

) čvora fiksiran je na 
\begin_inset Formula $\varphi_{\text{slack}}=0$
\end_inset

 i nije deo vektora stanja.
 Preslikavanje indeksa čvora 
\begin_inset Formula $k$
\end_inset

 na poziciju u vektoru stanja realizovano je preko pomoćnih funkcija 
\family typewriter
phiIdx(k)
\family default
 i 
\family typewriter
vIdx(k)
\family default
,
 pri čemu je slack čvor izuzet iz mape uglova (
\family typewriter
buildPhiMap()
\family default
).
\end_layout

\begin_layout Subsection
Admitansna matrica sistema
\end_layout

\begin_layout Standard
Svaka grana 
\begin_inset Formula $(i,j)$
\end_inset

 opisana je pi ekvivalentom,
 koji dozvoljava nesimetrične admitanse (bitno za transformatore sa faznim pomakom ili opštim 
\emph on
off-nominal
\emph default
 odnosom):
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
I_{i}=y_{11}V_{i}+y_{12}V_{j} & I_{j}=y_{21}V_{i}+y_{22}V_{j}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
Sve admitanse se čuvaju u 
\series bold
polarnom
\series default
 obliku,
 
\begin_inset Formula $y=|y|\angle\theta$
\end_inset

.
 Jedino mjesto gdje se privremeno prelazi u pravougaoni oblik je kod sastavljanja admitansne matrice sistema.
 Efektivni sopstveni članovi uključuju polovinu poprečne (shunt) admitanse grane $y_0$:
\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula 
\[
y^{\text{eff}}_{ii}=y_{ii}+\frac{y_{0}}{2}
\]

\end_inset

Za svaku granu 
\begin_inset Formula $(i,j)$
\end_inset

 doprinosi se sabiraju (pravougaono,
 pa se odmah vraćaju u polarni oblik):
\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula 
\begin{align*}
Y_{ii}\mathrel{+}=y^{\text{eff}}_{11} & Y_{jj}\mathrel{+}=y^{\text{eff}}_{22}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula 
\begin{align*}
Y_{ij}\mathrel{+}=y_{12} & Y_{ji}\mathrel{+}=y_{21}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
Rezultujuća matrica se čuva kao dvije 
\begin_inset Formula $N\times N$
\end_inset

 matrice (jedna matrica za modul,
 jedna matrica za ugao)u polarnom obliku:
\begin_inset Formula 
\[
Y_{\text{bus}}[i,j]=y_{ij}\angle\theta_{ij}=|Y_{ij}|\angle\arg(Y_{ij})
\]

\end_inset


\end_layout

\begin_layout Subsection
Funkcije mjerenja
\end_layout

\begin_layout Standard

\series bold
Pomoćne funkcije 
\series default
služe za efikasnije izračunavanje članova nelinearnih funkcija mjerenja,
 a definisane su sa:
\begin_inset Formula 
\[
Pt(y,\theta,d)=y\cos(d-\theta)
\]

\end_inset


\begin_inset Formula 
\[
Qt(y,\theta,d)=y\sin(d-\theta)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset VSpace defskip
\end_inset


\end_layout

\begin_layout Standard
\noindent

\series bold
Funkcija injektovane aktivne snage 
\series default
u čvor 
\begin_inset Formula $i$
\end_inset

 data je sa:
 
\begin_inset Formula 
\[
r_{i_{P}}(v,\varphi)=v^{2}_{i}y_{ii}\cos(\theta_{ii})+v_{i}\sum^{n}_{j=1,\,j\ne i}y_{ij}v_{j}\cos(\varphi_{i}-\theta_{ij}-\varphi_{j})-\hat{p}_{i}
\]

\end_inset


\end_layout

