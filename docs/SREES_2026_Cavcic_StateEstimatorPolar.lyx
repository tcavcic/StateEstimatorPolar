\begin_layout Subsection
Jacobian
\end_layout

\begin_layout Standard
Jacobian 
\begin_inset Formula $H$
\end_inset

 se u implementaciji nikad ne formira kao puna gusta 
\begin_inset Formula $M\times n$
\end_inset

 matrica.
 Za svako mjerenje 
\begin_inset Formula $m$
\end_inset

,
 u trenutku računanja 
\begin_inset Formula $h_{m}(x)$
\end_inset

,
 generiše se samo lista nenultih parova,
 jer red 
\begin_inset Formula $m$
\end_inset

 Jacobiana ima nenulte elemente isključivo u kolonama koje odgovaraju uglu i naponu čvorova koji direktno učestvuju u toj mjernoj funkciji,
 jer svaka mjerna funkcija zavisi samo od stanja u svojoj neposrednoj okolini,
 pa je 
\begin_inset Formula $H$
\end_inset

 izrazito rijetka (
\emph on
sparse
\emph default
) matrica.
\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $P_{\text{INJ}}$
\end_inset

 u čvoru
\series bold
 
\begin_inset Formula $i$
\end_inset

 
\series default
za 
\begin_inset Formula $l\ne i$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{P_{i}}}{\partial\varphi_{l}}=V_{i}V_{l}Qt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l}) & \ \frac{\partial h_{P_{i}}}{\partial V_{l}}=V_{i}Pt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l})
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
za 
\begin_inset Formula $l=i$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{P_{i}}}{\partial\varphi_{i}}=-V_{i}\sum_{l\ne i}V_{l}Qt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l})\  & \frac{\partial h_{P_{i}}}{\partial V_{i}}=\frac{h_{P_{i}}}{V_{i}}+V_{i}y_{ii}\cos\theta_{ii}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $Q_{\text{INJ}}$
\end_inset

 u čvoru
\series bold
 
\begin_inset Formula $i$
\end_inset

 
\series default
za 
\begin_inset Formula $l\ne i$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{Q_{i}}}{\partial\varphi_{l}}=-V_{i}V_{l}Pt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l}) & \ \frac{\partial h_{Q_{i}}}{\partial V_{l}}=V_{i}Qt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l})
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
za 
\begin_inset Formula $l=i$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{Q_{i}}}{\partial\varphi_{i}}=V_{i}\sum_{l\ne i}V_{l}Pt(y_{il},\theta_{il},\varphi_{i}-\varphi_{l})\  & \frac{\partial h_{Q_{i}}}{\partial V_{i}}=\frac{h_{Q_{i}}}{V_{i}}-V_{i}y_{ii}\sin\theta_{ii}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset VSpace defskip
\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $P_{\text{FLOW}}$
\end_inset


\series bold
 
\series default
kroz granu 
\begin_inset Formula $(i,j)$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{P_{ij}}}{\partial\varphi_{i}}=-V_{i}V_{j}Qt\  & \frac{\partial h_{P_{ij}}}{\partial\varphi_{j}}=V_{i}V_{j}Qt
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{P_{ij}}}{\partial V_{i}}=2V_{i}y^{(i\text{-}j)}_{ii}\cos\theta^{(i\text{-}j)}_{ii}+V_{j}Pt\  & \frac{\partial h_{P_{ij}}}{\partial V_{j}}=V_{i}Pt
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $Q_{\text{FLOW}}$
\end_inset


\series bold
 
\series default
kroz granu 
\begin_inset Formula $(i,j)$
\end_inset

:
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{Q_{ij}}}{\partial\varphi_{i}}=V_{i}V_{j}Pt\  & \frac{\partial h_{Q_{ij}}}{\partial\varphi_{j}}=-V_{i}V_{j}Pt
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula 
\begin{align*}
\frac{\partial h_{Q_{ij}}}{\partial V_{i}}=-2V_{i}y^{(i\text{-}j)}_{ii}\sin\theta^{(i\text{-}j)}_{ii}+V_{j}Qt\  & \frac{\partial h_{Q_{ij}}}{\partial V_{j}}=V_{i}Qt
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\noindent
gdje je 
\begin_inset Formula $d=\varphi_{i}-\varphi_{j}$
\end_inset

,
 
\begin_inset Formula $Qt=Qt(y^{(i\text{-}j)}_{ij},\theta^{(i\text{-}j)}_{ij},d)$
\end_inset

,
 te 
\begin_inset Formula $Pt$
\end_inset

 analogno 
\begin_inset Formula $Qt$
\end_inset

 .
\end_layout

\begin_layout Standard
\begin_inset VSpace defskip
\end_inset


\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $V_{\text{MAG}}$
\end_inset

 u čvoru 
\begin_inset Formula $i$
\end_inset

:
 
\begin_inset Formula 
\[
\frac{\partial h_{V_{i}}}{\partial V_{i}}=1
\]

\end_inset


\end_layout

\begin_layout Subsection
Gauss-Newton iteracija
\end_layout

\begin_layout Standard
\noindent
Neka je 
\begin_inset Formula $M$
\end_inset

 broj mjerenih varijabli,
 
\begin_inset Formula $z_{m}$
\end_inset

 izmjerena vrijednost,
 
\begin_inset Formula $\sigma_{m}$
\end_inset

 standardna devijacija mjernog instrumenta,
 i težina 
\begin_inset Formula $w_{m}=\frac{1}{\sigma^{2}_{m}}$
\end_inset

,
 odakle je matrica 
\begin_inset Formula $W=diag(w_{1},\dots,w_{M})$
\end_inset

.
 Rezidual mjerenja 
\begin_inset Formula $m$
\end_inset

 dat je sa 
\begin_inset Formula $r_{m}(x)=h_{m}(x)-z_{m}$
\end_inset

,
 u skladu sa funkcijama iz prethodnih poglavlja.
 Jacobian mjerenja je oblika 
\begin_inset Formula $H\in\mathbb{R}^{M\times n}$
\end_inset

,
 
\begin_inset Formula $H_{m,\bullet}=\nabla_{x}h_{m}(x)$
\end_inset

 čiji su elementi dati u prethodnoj sekciji.
 Jedna iteracija algoritma opisana je sa:
\begin_inset Formula 
\[
G(x)=H^{\top}WH
\]

\end_inset


\begin_inset Formula 
\[
g(x)=H^{\top}Wr(x)
\]

\end_inset


\begin_inset Formula 
\[
G(x)\Delta x=g(x)
\]

\end_inset


\end_layout

\begin_layout Standard
\noindent
što se po 
\begin_inset Formula $\Delta x$
\end_inset

 rješava LDLT faktorizacijom,
 odakle se dobije:
\begin_inset Formula 
\[
x^{(k+1)}=x^{(k)}-\Delta x
\]

\end_inset


\end_layout

\begin_layout Standard
\noindent
Te se iterativni postupak ponavlja dok se ne dostigne konergencija,
 opisana sa:
\begin_inset Formula 
\[
\max_{i}|\Delta x_{i}|<\varepsilon
\]

\end_inset


\end_layout

\begin_layout Standard
\noindent
ili dok se ne dosegne maksimalan broj iteracija.
 Korišteno je 
\begin_inset Formula $\varepsilon=10^{-6}$
\end_inset

 i 
\begin_inset Formula $maxiter$
\end_inset

= 50.
\end_layout

\begin_layout Standard
\noindent
\begin_inset Formula $G$
\end_inset

 je po konstrukciji simetrična i pozitivno semidefinitna,
 odnosno pozitivno definitna ako je sistem observabilan,
 zbog čega se rješava rijetkim 
\begin_inset Formula $LDL^{\top}$
\end_inset

 
\emph on
solverom.

\emph default
 Potreban uslov observabilnosti je 
\begin_inset Formula $M\ge n_{x}=2N-1$
\end_inset

.
 Ako faktorizacija ili rješavanje sistema u nekoj iteraciji ne uspiju (npr.
 singularna gain matrica usljed neobservabilnosti),
 estimacija se prekida uz odgovarajuću poruku greške.
\end_layout

\begin_layout Subsection

\emph on
Post-processing
\end_layout

\begin_layout Standard
Za svaku granu računaju se tokovi sa oba kraja,
 koristeći istu formulu kao za 
\begin_inset Formula $P_{\text{FLOW}}/Q_{\text{FLOW}}$
\end_inset

 mjerenja,
 jednom sa 
\begin_inset Formula $(i,j)$
\end_inset

 kao referentnim parom,
 jednom sa 
\begin_inset Formula $(j,i)$
\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
P_{ij}=V^{2}_{i}Y_{11}\cos\Theta_{11}+V_{i}V_{j}Y_{12}\cos(\varphi_{i}-\varphi_{j}-\Theta_{12})
\]

\end_inset


\begin_inset Formula 
\[
Q_{ij}=-V^{2}_{i}Y_{11}\sin\Theta_{11}+V_{i}V_{j}Y_{12}\sin(\varphi_{i}-\varphi_{j}-\Theta_{12})
\]

\end_inset


\begin_inset Formula 
\[
P_{ji}=V^{2}_{j}Y_{22}\cos\Theta_{22}+V_{j}V_{i}Y_{21}\cos(\varphi_{j}-\varphi_{i}-\Theta_{21})
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Q_{ji}=-V^{2}_{j}Y_{22}\sin\Theta_{22}+V_{j}V_{i}Y_{21}\sin(\varphi_{j}-\varphi_{i}-\Theta_{21})
\]

\end_inset

.
\end_layout

\begin_layout Standard
Snaga u čvoru računa se preko iste formule kao
\begin_inset Formula $P_{\text{INJ}}/Q_{\text{INJ}}$
\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
P_{k}=V_{k}\sum_{l}V_{l}y_{kl}\cos(\varphi_{k}-\theta_{kl}-\varphi_{l})
\]

\end_inset


\begin_inset Formula 
\[
Q_{k}=V_{k}\sum_{l}V_{l}y_{kl}\sin(\varphi_{k}-\theta_{kl}-\varphi_{l})
\]

\end_inset


\end_layout

