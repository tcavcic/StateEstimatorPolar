\end_inset

 data je sa:
 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
r_{ij_{P}}(v,\varphi)=v^{2}_{i}y^{(i\text{-}j)}_{ii}\cos(\theta^{(i\text{-}j)}_{ii})+v_{i}y^{(i\text{-}j)}_{ij}v_{j}\cos(\varphi_{i}-\theta^{(i\text{-}j)}_{ij}-\varphi_{j})-\hat{p}_{ij}
\]

\end_inset


